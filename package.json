{
  "name": "appturnos",
  "private": false,
  "description": "Sistema de gestión integral para restaurant con acera, mesas y pedidos a domicilio.",
  "author": "Ivan Fernandez",
  "license": "MIT",
  "keywords": [
    "restaurant",
    "pos",
    "delivery",
    "mesas",
    "gestion",
    "comedor"
  ],
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c green,cyan \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "node --watch-path=server server/index.js",
    "dev:start": "concurrently -k -n web,api -c green,cyan \"npm:dev:web\" \"npm:dev:api\"",
    "dev:detached": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-detached.ps1",
    "dev:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-server.ps1",
    "build": "vite build",
    "start": "node server/index.js",
    "start:lan": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-lan.ps1",
    "start:tunnel": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-tunnel.ps1",
    "startup:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-startup.ps1",
    "preview": "vite preview",
    "db:backup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backup-db.ps1"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.2",
    "classnames": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.460.0",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "to-ico": "^1.1.5",
    "vite": "^6.0.3"
  }
}
