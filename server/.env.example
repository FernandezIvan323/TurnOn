# Local (campos sueltos) O PaaS (DATABASE_URL):
# DATABASE_URL=postgresql://user:pass@host:5432/appturnos
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=tu_password
DB_NAME=appturnos
# 1 = SSL hacia Postgres (Render/Railway/Neon)
DB_SSL=0
DB_TZ=America/Bogota
PORT=3001
HOST=0.0.0.0
# 1 = orígenes de red privada. 0 = solo CORS_ORIGINS (usar 0 en producción web)
LAN_MODE=1
TRUST_PROXY=0
JWT_SECRET=genera-un-secreto-aleatorio-con-node -e "crypto.randomBytes(64).toString('hex')"
CORS_ORIGINS=http://localhost:5180,http://127.0.0.1:5180

