DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=tu_password
DB_NAME=appturnos
DB_TZ=America/Mexico_City
PORT=3001
# 0.0.0.0 = accesible desde celulares en la Wi‑Fi del local
HOST=0.0.0.0
# 1 = permite orígenes de red privada (LAN). 0 = solo CORS_ORIGINS
LAN_MODE=1
# 1 = detrás de Cloudflare Tunnel (trust proxy + log de recordatorio)
TUNNEL_MODE=0
# 1 = confiar en X-Forwarded-* (rate-limit / IP). Se activa solo con TUNNEL_MODE=1
TRUST_PROXY=0
JWT_SECRET=genera-un-secreto-aleatorio-con-node -e "crypto.randomBytes(64).toString('hex')"
CORS_ORIGINS=http://localhost:5180,http://127.0.0.1:5180
